# Ignore Python bytecode
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.venv/
venv/
ENV/
env/

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Logs - IMPORTANT: This prevents log files from being tracked
logs/
*.log
*.log.*
log/
*.out
*.err

# Configuration files with secrets
config/secrets.yaml

# Database files
*.db
*.sqlite3

# Temporary files
*.tmp
*.temp

# Coverage reports
htmlcov/
.coverage
.coverage.*
coverage.xml

# Pytest cache
.pytest_cache/

# mypy cache
.mypy_cache/

# Node.js (if using frontend build tools)
node_modules/
npm-debug.log*

# Backup files
*.bak
*.backup
